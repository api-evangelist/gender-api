  "item": [
    {
      "id": "f44a50d0-5d0f-4dcf-ba73-600eabd4c091",
      "name": "Get gender for a name",
      "request": {
        "name": "Get gender for a name",
        "description": {
          "content": "Returns a gender prediction (male, female, or unknown) for the supplied first name with an accuracy score. Supports localization by country, IP, or locale, and parsing of full names or email addresses.",
          "type": "text/plain"
        },
        "url": {
          "path": [
            "get"
          ],
          "host": [
            "{{baseUrl}}"
          ],
          "query": [
            {
              "disabled": false,
              "key": "name",
              "value": "<string>",
              "description": "First name (or full name with split=true) to look up. Supports semicolon-separated lists when multi=true."
            },
            {
              "disabled": false,
              "key": "email",
              "value": "<email>",
              "description": "Email address from which to extract the name."
            },
            {
              "disabled": false,
              "key": "country",
              "value": "<string>",
              "description": "ISO 3166-1 alpha-2 country code to localize the lookup."
            },
            {
              "disabled": false,
              "key": "ip",
              "value": "<string>",
              "description": "Client IP address used to localize the lookup."
            },
            {
              "disabled": false,
              "key": "locale",
              "value": "<string>",
              "description": "Browser locale (e.g. en_US, de_DE) used to localize the lookup."
            },
            {
              "disabled": false,
              "key": "split",
              "value": "<boolean>",
              "description": "When true, splits a full name and resolves the first name automatically."
            },
            {
              "disabled": false,
              "key": "multi",
              "value": "<boolean>",
              "description": "When true, accepts a semicolon-separated list of names (max 100 per request)."
            },
            {
              "disabled": false,
              "key": "key",
              "value": "<string>",
              "description": "(Required) Gender-API key (alternatively send via apiKey query or Authorization header per account configuration)."
            }
          ],
          "variable": []
        },
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "method": "GET",
